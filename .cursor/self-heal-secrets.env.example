# Copy to .cursor/self-heal-secrets.env (gitignored). One Sentry token for poll + resolve + alerts.
#
# Create at: https://jtlh-ltd.sentry.io/settings/account/api/auth-tokens/
# Name: cursor-self-heal
# Permissions (UI labels):
#   Issue & Event — Read & Write   (event:read + event:write — required)
#   Alerts — Read & Write          (alerts:read + alerts:write)
#   Organization — Read            (org:read)
#   Project — Read                 (project:read)
#
# Sync once to Render: .\scripts\sync-self-heal-env-to-render.ps1

CURSOR_SELF_HEAL_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/YOUR_AUTOMATION_ID
CURSOR_SELF_HEAL_WEBHOOK_AUTH=crsr_...
SENTRY_SELF_HEAL_RELAY_SECRET=generate-a-random-secret
SENTRY_AUTH_TOKEN=sntryu_...
AUTOMATION_SMOKE_ENABLED=false
HEAL_TEST_ENABLED=false
SENTRY_SELF_HEAL_POLLER_ENABLED=true
# Optional additional automations (create webhook automations in Cursor, then paste URLs here):
# CURSOR_CI_FAIL_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/...
# CURSOR_CI_FAIL_WEBHOOK_AUTH=crsr_...
# CURSOR_DEPENDABOT_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/...
# CURSOR_DEPENDABOT_WEBHOOK_AUTH=crsr_...
# CURSOR_DEPLOY_FAIL_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/...
# CURSOR_DEPLOY_FAIL_WEBHOOK_AUTH=crsr_...
# RENDER_DEPLOY_FAIL_POLLER_ENABLED=true
# RENDER_API_KEY=rnd_...   (read-only; for deploy-failure poller on Render)
# RENDER_SERVICE_ID=srv-d2vvdqbuibrs73dq57ug
