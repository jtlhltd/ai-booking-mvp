# ============================================
# Environment variables template
# See docs/HOW-TO-RUN.md. Regenerate: node scripts/generate-env-template.js
# ============================================

# ============================================
# CRITICAL — required for basic functionality
# ============================================

# Admin API key for authentication
API_KEY=

# Database connection string (PostgreSQL or SQLite)
DATABASE_URL=

# ============================================
# VAPI — AI calling
# ============================================

# Vapi private key for API calls
VAPI_PRIVATE_KEY=

# Default Vapi assistant ID
VAPI_ASSISTANT_ID=

# Vapi phone number ID for making calls
VAPI_PHONE_NUMBER_ID=

# Template assistant ID for cloning
VAPI_TEMPLATE_ASSISTANT_ID=

# Vapi public key (alternative to private key)
# VAPI_PUBLIC_KEY=

# Vapi API key (alternative to private key)
# VAPI_API_KEY=

# Vapi API origin (default: https://api.vapi.ai)
# VAPI_ORIGIN=

# Enable test mode (true/false)
# VAPI_TEST_MODE=

# Enable dry run mode (true/false)
# VAPI_DRY_RUN=

# ============================================
# TWILIO — SMS
# ============================================

# Twilio account SID
TWILIO_ACCOUNT_SID=

# Twilio auth token
TWILIO_AUTH_TOKEN=

# Twilio phone number for SMS
TWILIO_FROM_NUMBER=

# Twilio messaging service SID
TWILIO_MESSAGING_SERVICE_SID=

# ============================================
# GOOGLE CALENDAR
# ============================================

# Google service account email
GOOGLE_CLIENT_EMAIL=

# Google service account private key
GOOGLE_PRIVATE_KEY=

# Google private key (base64 encoded)
GOOGLE_PRIVATE_KEY_B64=

# Google Calendar ID (default: primary)
GOOGLE_CALENDAR_ID=

# ============================================
# EMAIL
# ============================================

# Email username for SMTP
EMAIL_USER=

# Email password/app password
EMAIL_PASS=

# Your email address
YOUR_EMAIL=

# ============================================
# BUSINESS SEARCH APIs (optional)
# ============================================

# Google Places API key
GOOGLE_PLACES_API_KEY=

# Companies House API key
COMPANIES_HOUSE_API_KEY=

# Google Custom Search API key
GOOGLE_SEARCH_API_KEY=

# Google Custom Search Engine ID
GOOGLE_SEARCH_ENGINE_ID=

# ============================================
# OTHER CONFIGURATION
# ============================================

# Base URL of your application
BASE_URL=

# Server port (default: 3000)
PORT=

# Timezone (default: Europe/London)
TZ=

# Timezone (alternative to TZ)
TIMEZONE=

# Node environment (development/production)
NODE_ENV=

# Test phone number for demo calls
TEST_PHONE_NUMBER=

# ============================================
# ADVANCED (optional)
# ============================================

# Call consent line text
# CONSENT_LINE=

# Default client key for inbound calls
# DEFAULT_CLIENT_KEY=

# Slack webhook URL for notifications
# SLACK_WEBHOOK_URL=

# Bootstrap clients JSON
# BOOTSTRAP_CLIENTS_JSON=

# Google Sheets ID for bookings
# BOOKINGS_SHEET_ID=

# Google Sheets ID for logistics
# LOGISTICS_SHEET_ID=

# Email for callback notifications
# CALLBACK_INBOX_EMAIL=

# Enable demo mode (true/false)
# DEMO_MODE=

# Enable booking debug logs (true/false)
# LOG_BOOKING_DEBUG=

# Receptionist test mode
# RECEPTIONIST_TEST_MODE=

# Demo telemetry path
# DEMO_TELEMETRY_PATH=

# Receptionist telemetry path
# RECEPTIONIST_TELEMETRY_PATH=

# Demo script path
# DEMO_SCRIPT_PATH=

# Database type (postgres/sqlite)
# DB_TYPE=

# Logging level (debug/info/warn/error)
# LOG_LEVEL=
