{
  "name": "ai-booking-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "render-start": "node run-migration.js && node server.js",
    "render-build": "echo \"no build step\"",
    "migrate": "node run-migration.js",
    "env:test": "node scripts/write-test-database-url.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:coverage-hotspots": "npm run test:coverage && node scripts/coverage-hotspots.mjs",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=integration",
    "test:integration-db": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration/db-sqlite-queue-and-journey.test.js",
    "test:integration-lite": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/routes tests/db",
    "test:detect-leaks": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --runInBand --testPathPattern=\"tests[/\\\\](routes|db|unit)[/\\\\]\"",
    "test:ci": "node scripts/run-test-ci.mjs",
    "test:route-inventory": "node scripts/route-test-inventory.mjs",
    "test:server-inline-inventory": "node scripts/server-inline-route-inventory.mjs",
    "test:canaries": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/canaries",
    "check:policy": "node scripts/check-policy.mjs",
    "audit:ci": "npm audit --omit=dev --audit-level=moderate",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:local": "powershell.exe -ExecutionPolicy Bypass -File .\\tests\\smoke.ps1",
    "load-test": "node scripts/load-test.js",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "postrelease": "git push --follow-tags origin main"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^9.6.0",
    "chrono-node": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-holidays": "^3.26.12",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "googleapis": "^171.4.0",
    "joi": "^17.13.3",
    "luxon": "^3.7.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "redis": "^5.12.1",
    "socket.io": "^4.8.1",
    "twilio": "^4.23.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "body-parser": "^2.2.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "standard-version": "^9.5.0",
    "supertest": "^6.3.4"
  },
  "volta": {
    "node": "20.16.0"
  }
}
