# .env.example — copy to `.env` and fill in. See docs/HOW-TO-RUN.md
# Exhaustive list from the codebase: node scripts/generate-env-template.js

# --- Required for production-style runs (see HOW-TO-RUN) ---
DATABASE_URL=
API_KEY=
# Vapi: set VAPI_PRIVATE_KEY and/or VAPI_API_KEY (at least one for API calls)
VAPI_PRIVATE_KEY=
# VAPI_API_KEY=
VAPI_ASSISTANT_ID=
# Set to true to log full Vapi webhook payloads, transcripts, and logistics debug (noisy; avoid in production).
# VAPI_WEBHOOK_VERBOSE=true

# --- Server ---
PORT=3000

# Sentry error tracking (optional — leave unset to disable; see instrument.mjs)
# Create a project at sentry.io → Settings → Client Keys (DSN)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Leave unset for defaults (0.1 prod / 1.0 dev). Do NOT set to an empty value — that disables spans.
# APP_NAME=ai-booking-mvp
# SENTRY_AUTH_TOKEN=  # Org auth token for source map upload at build (Render build env)
# SENTRY_PROJECT=ai-booking-mvp
# Temporary: enable GET /debug-sentry to send a test error (remove after verifying Sentry).
# DEBUG_SENTRY=true
# HEAL_TEST_ENABLED=true  # enables GET /heal-test for Sentry self-heal automation tests only
# AUTOMATION_SMOKE_ENABLED=true  # enables GET /automation-smoke for self-heal loop smoke tests only
# CURSOR_SELF_HEAL_* and SENTRY_SELF_HEAL_RELAY_SECRET: copy .cursor/self-heal-secrets.env.example
# to .cursor/self-heal-secrets.env (gitignored), then run scripts/sync-self-heal-env-to-render.ps1 once.

# Sentry org token for `npm run setup:sentry-alerts` (alerts:write scope). Build uses this too.
# SENTRY_AUTH_TOKEN=
# SENTRY_NOTIFY_USER_ID=4654133
# SENTRY_NOTIFY_USER_ID_CRITICAL=4654133
# SENTRY_NOTIFY_USER_ID_WARNING=4654133

# Better Stack — uptime monitors + Cursor MCP (${env:BETTERSTACK_API_TOKEN} in ~/.cursor/mcp.json)
# BETTERSTACK_API_TOKEN=
# BETTERSTACK_TEAM_ID=
# AI_BOOKING_HEALTH_URL=https://ai-booking-mvp.onrender.com/health/lb
# TERRY_HEALTH_URL=https://terry-spec-converter.onrender.com/api/health

# Tiered alert routing (incident-grouped; see lib/alert-router.js)
# ALERT_CRITICAL_EMAIL=ops-critical@example.com
# ALERT_WARNING_EMAIL=ops-warnings@example.com
# SLACK_WEBHOOK_URL_CRITICAL=https://hooks.slack.com/services/...
# SLACK_WEBHOOK_URL_WARNING=https://hooks.slack.com/services/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERTS_SUPPRESSED=true
# Public URL of this app (webhooks, links)
# BASE_URL=https://your-app.onrender.com

# Twilio (for real notify.send in future)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (for real notify.send in future)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google Calendar (for real calendar.checkAndBook)
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary

# Email (nodemailer — see lib/messaging-service.js)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Outbound A/B sample-ready emails go to YOUR_EMAIL (then tenant dashboard fallback if unset).
YOUR_EMAIL=
# Hourly call-quality alert emails (plain + HTML). Default off; set true to enable.
# ENABLE_QUALITY_MONITORING_EMAILS=true
OUTBOUND_AB_MIN_SAMPLES_PER_VARIANT=50
PUBLIC_DASHBOARD_URL=

# Comma-separated client_keys: outreach-only client dashboard layout + A/B upload without API key (see server isDashboardSelfServiceClient).
# Unset = default d2d-xpress-tom. Set to comma-list to extend; set to empty to require API key for all tenants.
# DASHBOARD_SELF_SERVICE_CLIENT_KEYS=d2d-xpress-tom

# Ops invariant checks (cron ~5m, lib/ops-invariants.js). Set YOUR_EMAIL when enabling email alerts.
# OPS_INVARIANTS_ALL_CLIENTS=true
# OPS_INVARIANTS_EMAIL_ALERTS=true
# OPS_INVARIANTS_CLIENT_KEY=d2d-xpress-tom
# OPS_INVARIANTS_LOG_OK=false
# OPS_INVARIANTS_LOOKBACK_MINUTES=60
# OPS_INVARIANTS_STUCK_PROCESSING_MINUTES=15
# OPS_INVARIANTS_ON_HOUR_SPIKE_THRESHOLD=25
# Terry Foods ingredient outreach (Matt) — optional per-tenant Vapi IDs
# TERRY_VAPI_ASSISTANT_ID=   # optional; run node scripts/provision-terry-call-bot.mjs to create placeholder
# TERRY_VAPI_PHONE_NUMBER_ID=
# TERRY_VAPI_STRUCTURED_OUTPUT_ID=   # optional; defaults to VAPI_STRUCTURED_OUTPUT_ID
# RESEED_TERRY_INGREDIENTS_SEQUENCE=1

# Allow lead import endpoint to fall back to env VAPI_ASSISTANT_ID for dialing when tenant config is missing.
# Default false (recommended).
# IMPORT_ALLOW_ENV_VAPI_FALLBACK=false

# Postgres pool size per web process (default 25, max 80). Raise if you run many parallel DB-heavy routes; lower on tiny DB tiers.
# DB_POOL_MAX=35

# Per-statement timeout (ms) on each pooled PG connection. Default 20000 local; 60000 when RENDER=true (see db/connection.js).
# Raise if /api/client-dashboard cancels mid-query; cap 300000. Helps avoid opaque HTML 502 from the edge when DB work is slow.
# DB_STATEMENT_TIMEOUT_MS=90000

# In-memory cache for GET /api/client-dashboard/:clientKey (ms). Default 10000 local; 30000 on Render.
# CLIENT_DASHBOARD_CACHE_MS=30000

# Optional: override the persisted analytics floor (see call_analytics_floor table). Use 1970-01-01T00:00:00.000Z to include all history.
# CALL_ANALYTICS_SINCE=

# Slow query alerts (lib/query-performance-tracker.js). Raise critical threshold to reduce email noise under load.
# SLOW_QUERY_THRESHOLD=1000
# CRITICAL_QUERY_THRESHOLD=8000
# In-memory caps are per web process; with multiple instances set a DB-wide minimum gap (Postgres):
# SLOW_QUERY_EMAIL_DB_MIN_INTERVAL_MS=2700000
# SLOW_QUERY_EMAIL_COOLDOWN_MS=1800000
# SLOW_QUERY_EMAIL_GLOBAL_MAX=6

# Tom / Call Bot split
# LOGISTICS_SHEET_WRITES_IN_CORE=1
# DISABLE_TOM_VERTICAL_ROUTES=0
# Tenant consumer_webhook_json (Postgres): {"url":"https://tom-app/webhooks/callbot","secret":"...","enabled":true,"events":["call.completed"]}
