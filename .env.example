# .env.example — copy to `.env` and fill in. See docs/HOW-TO-RUN.md
# Exhaustive list from the codebase: node scripts/generate-env-template.js

# --- Required for production-style runs (see HOW-TO-RUN) ---
DATABASE_URL=
API_KEY=
# Vapi: set VAPI_PRIVATE_KEY and/or VAPI_API_KEY (at least one for API calls)
VAPI_PRIVATE_KEY=
# VAPI_API_KEY=
VAPI_ASSISTANT_ID=

# --- Server ---
PORT=3000
# Public URL of this app (webhooks, links)
# BASE_URL=https://your-app.onrender.com

# Twilio (for real notify.send in future)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (for real notify.send in future)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google Calendar (for real calendar.checkAndBook)
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary

# Email (nodemailer — see lib/messaging-service.js)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Outbound A/B sample-ready emails go to YOUR_EMAIL (then tenant dashboard fallback if unset).
YOUR_EMAIL=
OUTBOUND_AB_MIN_SAMPLES_PER_VARIANT=50
PUBLIC_DASHBOARD_URL=

# Comma-separated client_keys: outreach-only client dashboard layout + A/B upload without API key (see server isDashboardSelfServiceClient).
# Default is empty (self-service is opt-in).
# DASHBOARD_SELF_SERVICE_CLIENT_KEYS=

# Allow lead import endpoint to fall back to env VAPI_ASSISTANT_ID for dialing when tenant config is missing.
# Default false (recommended).
# IMPORT_ALLOW_ENV_VAPI_FALLBACK=false

# Postgres pool size per web process (default 25, max 80). Raise if you run many parallel DB-heavy routes; lower on tiny DB tiers.
# DB_POOL_MAX=35

# Optional: override the persisted analytics floor (see call_analytics_floor table). Use 1970-01-01T00:00:00.000Z to include all history.
# CALL_ANALYTICS_SINCE=

# Slow query alerts (lib/query-performance-tracker.js). Raise critical threshold to reduce email noise under load.
# SLOW_QUERY_THRESHOLD=1000
# CRITICAL_QUERY_THRESHOLD=8000
