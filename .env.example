# .env.example
PORT=3000

# Twilio (for real notify.send in future)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (for real notify.send in future)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google Calendar (for real calendar.checkAndBook)
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary

# Email (nodemailer — see lib/messaging-service.js)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Outbound A/B: operator inbox — one email when each variant has ≥ N distinct leads (no auto winner).
# Checked in order: OUTBOUND_AB_SAMPLE_READY_EMAIL, then YOUR_EMAIL, then tenant vapi fallback.
OUTBOUND_AB_SAMPLE_READY_EMAIL=
YOUR_EMAIL=
OUTBOUND_AB_MIN_SAMPLES_PER_VARIANT=30
PUBLIC_DASHBOARD_URL=